{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug tests",
            "type": "debugpy",
            "request": "launch",
            "program": "manage.py",
            "args": [
                "test",
            ],
            "django": true,
            "console": "integratedTerminal"
        },
        {
            "name": "Python: Django (no reload)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "args": [
                "runserver",
                "--noreload"
            ],
            "django": true,
            "console": "integratedTerminal"
        },
        {
            "name": "Debug server",
            "type": "debugpy",
            "request": "launch",
            "program": "manage.py",
            "console": "integratedTerminal",
            "args": "runserver"
        }
    ]
}